HOST_VOSK_MODELS_PATH=./models

VOSK_MODEL=vosk-model-small-ru-0.22
AUDIO_SAMPLERATE=16000
AUDIO_BLOCK_SIZE=4000
PULSE_SERVER=unix:/mnt/wslg/PulseServer
AUDIO_DEVICE=default

LLM_API_URL=http://host.docker.internal:8000/v1
LLM_API_KEY=not-needed
LLM_MODEL=Qwen/Qwen2.5-3B-Instruct
SYS_PROMPT_PATH=/workspace/prompts/decomposer_system_prompt.txt

DISPLAY=:0
WAYLAND_DISPLAY=wayland-0
XDG_RUNTIME_DIR=/mnt/wslg/runtime-dir
LD_LIBRARY_PATH=/usr/lib/wsl/lib
MESA_D3D12_DEFAULT_ADAPTER_NAME=NVIDIA
LIBGL_ALWAYS_SOFTWARE=1
TARGET_VIDEO_FPS=10
TARGET_VIDEO_WIDTH=640
TARGET_VIDEO_HEIGHT=480

CAMERA_RAW_TOPIC=/camera/camera/image_raw/compressed

SAM3_SERVER_URL=http://host.docker.internal:8120/websocket
