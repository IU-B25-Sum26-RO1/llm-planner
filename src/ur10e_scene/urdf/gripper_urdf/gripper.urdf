<?xml version="1.0"?>
<robot name="linear_gripper">
  <mujoco>
    <compiler meshdir="meshes" discardvisual="false"/>
  </mujoco>

  <link name="gripper_base_link">
    <inertial>
      <origin xyz="0 0 0.0055" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.001245" ixy="0" ixz="0" iyy="0.002728" iyz="0" izz="0.003051"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find ur10e_scene)/urdf/gripper_urdf/meshes/base.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="dark_gray">
        <color rgba="0.75 0.75 0.72 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find ur10e_scene)/urdf/gripper_urdf/meshes/base.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </collision>
  </link>

  <link name="left_jaw_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.000151" ixy="0" ixz="0" iyy="0.000258" iyz="0" izz="0.000156"/>
    </inertial>
    <visual>
      <origin xyz="-0.041639558 -0.013 -0.04754972" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find ur10e_scene)/urdf/gripper_urdf/meshes/tip.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="dark_gray">
        <color rgba="0.75 0.75 0.72 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.041639558 -0.013 -0.04754972" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find ur10e_scene)/urdf/gripper_urdf/meshes/tip.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </collision>
  </link>

  <link name="right_jaw_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.000151" ixy="0" ixz="0" iyy="0.000258" iyz="0" izz="0.000156"/>
    </inertial>
    <visual>
      <origin xyz="0.041639558 0.013 -0.04754972" rpy="0 0 3.14159265359"/>
      <geometry>
        <mesh filename="file://$(find ur10e_scene)/urdf/gripper_urdf/meshes/tip.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="dark_gray">
        <color rgba="0.75 0.75 0.72 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.041639558 0.013 -0.04754972" rpy="0 0 3.14159265359"/>
      <geometry>
        <mesh filename="file://$(find ur10e_scene)/urdf/gripper_urdf/meshes/tip.stl" scale="0.001 0.001 0.001" />
      </geometry>
    </collision>
  </link>

  <joint name="left_jaw_joint" type="prismatic">
    <parent link="gripper_base_link"/>
    <child link="left_jaw_link"/>
    <origin xyz="-0.04488 0.000189 0.09354972" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.068" effort="120" velocity="0.05"/>
    <dynamics damping="8" friction="1"/>
  </joint>

  <joint name="right_jaw_joint" type="prismatic">
    <parent link="gripper_base_link"/>
    <child link="right_jaw_link"/>
    <origin xyz="0.04488 0.000189 0.09354972" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0" upper="0.068" effort="120" velocity="0.05"/>
    <dynamics damping="8" friction="1"/>
    <mimic joint="left_jaw_joint" multiplier="1" offset="0"/>
  </joint>

  <transmission name="left_jaw_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="left_jaw_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="linear_actuator">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
</robot>

