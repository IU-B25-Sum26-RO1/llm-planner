<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:property name="cam_fps" value="$(env TARGET_VIDEO_FPS)" />
  <xacro:property name="cam_width" value="$(env TARGET_VIDEO_WIDTH)" />
  <xacro:property name="cam_height" value="$(env TARGET_VIDEO_HEIGHT)" />

  <xacro:macro name="realsense_d435" params="parent *origin">
    
    <link name="camera_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.025 0.09 0.025"/>
        </geometry>
        <material name="silver">
          <color rgba="0.75 0.75 0.75 1"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <box size="0.025 0.09 0.025"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.072"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>

    <joint name="camera_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}"/>
      <child link="camera_link"/>
    </joint>

    <link name="camera_color_optical_frame"/>
    <joint name="camera_optical_joint" type="fixed">
      <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
      <parent link="camera_link"/>
      <child link="camera_color_optical_frame"/>
    </joint>

    <gazebo reference="camera_link">
      <sensor type="depth" name="camera">
        <always_on>true</always_on>
        <update_rate>${cam_fps}</update_rate>
        <camera>
          <horizontal_fov>1.50098</horizontal_fov> <!-- Около 86 градусов (как у D435) -->
          <image>
            <width>${cam_width}</width>
            <height>${cam_height}</height>
            <format>B8G8R8</format>
          </image>
          <clip>
            <near>0.01</near>
            <far>10.0</far>
          </clip>
        </camera>
        <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
          <ros>
            <namespace>camera</namespace>
            <remapping>~/image_raw:=color/image_raw</remapping>
            <remapping>~/camera_info:=color/camera_info</remapping>
            <remapping>~/depth/image_raw:=depth/image_raw</remapping>
            <remapping>~/depth/camera_info:=depth/camera_info</remapping>
            <remapping>~/points:=depth/color/points</remapping>
          </ros>
          <camera_name>camera</camera_name>
          <frame_name>camera_color_optical_frame</frame_name>
          <min_depth>0.1</min_depth>
          <max_depth>10.0</max_depth>
        </plugin>
      </sensor>
    </gazebo>
  </xacro:macro>
</robot>
