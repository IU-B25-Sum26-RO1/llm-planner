<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="ur10e_station">
    
    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>

    <plugin name="gazebo_ros_state" filename="libgazebo_ros_state.so">
      <ros>
        <namespace>/gazebo</namespace>
      </ros>
      <update_rate>20.0</update_rate>
    </plugin>

    <model name="table">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="link">
        
        <collision name="top_col">
          <pose>0 0 0.785 0 0 0</pose>
          <geometry><box><size>1.0 1.0 0.03</size></box></geometry>
        </collision>
        <visual name="top_vis">
          <pose>0 0 0.785 0 0 0</pose>
          <geometry><box><size>1.0 1.0 0.03</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/DarkGrey</name></script></material>
        </visual>

        <collision name="leg1_col"><pose>0.45 0.45 0.385 0 0 0</pose><geometry><box><size>0.05 0.05 0.77</size></box></geometry></collision>
        <visual name="leg1_vis"><pose>0.45 0.45 0.385 0 0 0</pose><geometry><box><size>0.05 0.05 0.77</size></box></geometry><material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/DarkGrey</name></script></material></visual>

        <collision name="leg2_col"><pose>-0.45 0.45 0.385 0 0 0</pose><geometry><box><size>0.05 0.05 0.77</size></box></geometry></collision>
        <visual name="leg2_vis"><pose>-0.45 0.45 0.385 0 0 0</pose><geometry><box><size>0.05 0.05 0.77</size></box></geometry><material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/DarkGrey</name></script></material></visual>

        <collision name="leg3_col"><pose>0.45 -0.45 0.385 0 0 0</pose><geometry><box><size>0.05 0.05 0.77</size></box></geometry></collision>
        <visual name="leg3_vis"><pose>0.45 -0.45 0.385 0 0 0</pose><geometry><box><size>0.05 0.05 0.77</size></box></geometry><material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/DarkGrey</name></script></material></visual>

        <collision name="leg4_col"><pose>-0.45 -0.45 0.385 0 0 0</pose><geometry><box><size>0.05 0.05 0.77</size></box></geometry></collision>
        <visual name="leg4_vis"><pose>-0.45 -0.45 0.385 0 0 0</pose><geometry><box><size>0.05 0.05 0.77</size></box></geometry><material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/DarkGrey</name></script></material></visual>
      </link>
    </model>

    <!-- Small 45-45-90 wedge ramp from 3 flat plates, near +Y table edge opposite the cubes -->
    <model name="ramp">
      <pose>0.25 0.4 1.95 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>10.0</mass>
          <pose>0 -0.04 0.03 0 0 0</pose>
          <inertia>
            <ixx>0.15</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.08</iyy><iyz>0</iyz>
            <izz>0.18</izz>
          </inertia>
        </inertial>

        <!-- Horizontal leg of the right triangle -->
        <collision name="base_col">
          <pose>0 -0.05 0.004 0 0 0</pose>
          <geometry><box><size>0.10 0.10 0.008</size></box></geometry>
          <surface>
            <friction><ode><mu>0.3</mu><mu2>0.3</mu2></ode></friction>
            <contact>
              <ode><kp>100000.0</kp><kd>100.0</kd><max_vel>0.0</max_vel><min_depth>0.001</min_depth></ode>
            </contact>
          </surface>
        </collision>
        <visual name="base_vis">
          <pose>0 -0.05 0.004 0 0 0</pose>
          <geometry><box><size>0.10 0.10 0.008</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Orange</name></script></material>
        </visual>

        <!-- Vertical leg of the right triangle -->
        <collision name="back_col">
          <pose>0 -0.004 0.05 0 0 0</pose>
          <geometry><box><size>0.10 0.008 0.10</size></box></geometry>
          <surface>
            <friction><ode><mu>0.3</mu><mu2>0.3</mu2></ode></friction>
            <contact>
              <ode><kp>100000.0</kp><kd>100.0</kd><max_vel>0.0</max_vel><min_depth>0.001</min_depth></ode>
            </contact>
          </surface>
        </collision>
        <visual name="back_vis">
          <pose>0 -0.004 0.05 0 0 0</pose>
          <geometry><box><size>0.10 0.008 0.10</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Orange</name></script></material>
        </visual>

        <!-- Hypotenuse: the 45° ramp surface -->
        <collision name="slope_col">
          <pose>0 -0.05 0.05 0.785398 0 0</pose>
          <geometry><box><size>0.10 0.14142 0.008</size></box></geometry>
          <surface>
            <friction><ode><mu>0.2</mu><mu2>0.2</mu2></ode></friction>
            <contact>
              <ode><kp>100000.0</kp><kd>100.0</kd><max_vel>0.0</max_vel><min_depth>0.001</min_depth></ode>
            </contact>
          </surface>
        </collision>
        <visual name="slope_vis">
          <pose>0 -0.05 0.05 0.785398 0 0</pose>
          <geometry><box><size>0.10 0.14142 0.008</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Orange</name></script></material>
        </visual>
      </link>
    </model>

    <!-- Medium ball in the middle of the table (diameter ≈ cube size) -->
    <model name="ball">
      <pose>0.0 0.0 0.825 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>1.0</mass>
          <inertia>
            <ixx>3.0e-5</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>3.0e-5</iyy><iyz>0</iyz>
            <izz>3.0e-5</izz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry><sphere><radius>0.025</radius></sphere></geometry>
          <surface>
            <friction><ode><mu>0.4</mu><mu2>0.4</mu2></ode></friction>
            <contact>
              <ode><kp>10000.0</kp><kd>1.0</kd><max_vel>5.0</max_vel><min_depth>0.001</min_depth></ode>
            </contact>
          </surface>
        </collision>
        <visual name="visual">
          <geometry><sphere><radius>0.025</radius></sphere></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/White</name></script></material>
        </visual>
      </link>
    </model>

    <!-- Light 3-cube pyramid on the right (-Y) of the manipulator -->
    <model name="pyramid_cube_1">
      <pose>0.225 -0.35 0.825 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>0.015</mass>
          <inertia>
            <ixx>6.25e-6</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>6.25e-6</iyy><iyz>0</iyz>
            <izz>6.25e-6</izz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry><box><size>0.05 0.05 0.05</size></box></geometry>
          <surface>
            <friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction>
            <contact>
              <ode><kp>10000.0</kp><kd>10.0</kd><max_vel>0.0</max_vel><min_depth>0.002</min_depth></ode>
            </contact>
          </surface>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 0.05 0.05</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Green</name></script></material>
        </visual>
      </link>
    </model>

    <model name="pyramid_cube_2">
      <pose>0.275 -0.35 0.825 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>0.015</mass>
          <inertia>
            <ixx>6.25e-6</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>6.25e-6</iyy><iyz>0</iyz>
            <izz>6.25e-6</izz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry><box><size>0.05 0.05 0.05</size></box></geometry>
          <surface>
            <friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction>
            <contact>
              <ode><kp>10000.0</kp><kd>10.0</kd><max_vel>0.0</max_vel><min_depth>0.002</min_depth></ode>
            </contact>
          </surface>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 0.05 0.05</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Blue</name></script></material>
        </visual>
      </link>
    </model>

    <model name="pyramid_cube_3">
      <pose>0.25 -0.35 0.875 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>0.015</mass>
          <inertia>
            <ixx>6.25e-6</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>6.25e-6</iyy><iyz>0</iyz>
            <izz>6.25e-6</izz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry><box><size>0.05 0.05 0.05</size></box></geometry>
          <surface>
            <friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction>
            <contact>
              <ode><kp>10000.0</kp><kd>10.0</kd><max_vel>0.0</max_vel><min_depth>0.002</min_depth></ode>
            </contact>
          </surface>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 0.05 0.05</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Red</name></script></material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
